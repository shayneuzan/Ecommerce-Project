{% extends "layout.html.twig" %}

{% block title %}Home{% endblock %}

{% block content %}

{# ── Hero ── #}
<section class="hero">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-7">
                <h1 class="hero-title">Your next adventure <span class="text-teal">starts here.</span></h1>
                <p class="hero-subtitle">Browse handpicked vacation packages to the world's most beautiful destinations. Hotels, guides and memories included.</p>
                <div class="d-flex gap-3 justify-content-center flex-wrap">
                    <a href="{{ base_path }}/packages" class="btn btn-teal btn-lg px-4">Browse Packages</a>
                    {% if not (app_authenticated ?? false) %}
                        <a href="{{ base_path }}/auth/register" class="btn btn-outline-light btn-lg px-4">Create Account</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>

{# ── Featured packages ── #}
<section class="py-5">
    <div class="container">
        <div class="mb-4">
            <h2 class="section-title">Popular Destinations</h2>
            <p class="text-muted">Explore our most booked vacation packages</p>
        </div>

        <div class="row g-4">
            {% for package in packages %}
                <div class="col-lg-3 col-md-6">
                    <div class="card package-card h-100">
                        <img
                            src="{{ package.image_url ?? 'https://images.unsplash.com/photo-1488646953014-85cb44e25828?w=800' }}"
                            class="card-img-top package-card-img"
                            alt="{{ package.title }}"
                            loading="lazy"
                        >
                        <div class="card-body d-flex flex-column">
                            <p class="package-destination">{{ package.city ?? 'Destination' }}</p>
                            <h5 class="card-title package-title">{{ package.title }}</h5>
                            <p class="card-text text-muted small flex-grow-1">{{ package.description }}</p>
                            <div class="d-flex gap-3 my-2">
                                <span class="small text-muted">{{ package.duration_days }} days</span>
                                <span class="small text-muted">{{ package.available_slots }} slots left</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                                <div>
                                    <div class="price-label">From</div>
                                    <div class="price-value">${{ package.price }}<span class="price-per">/person</span></div>
                                </div>
                                <a href="{{ base_path }}/packages/{{ package.id }}" class="btn btn-teal btn-sm">View Deal</a>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center py-5 text-muted">
                    <p class="fs-5">No packages available yet.</p>
                </div>
            {% endfor %}
        </div>

        <div class="text-center mt-4">
            <a href="{{ base_path }}/packages" class="btn btn-outline-navy btn-lg px-5">View All Packages</a>
        </div>
    </div>
</section>

{% endblock %}