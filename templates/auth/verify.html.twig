{% extends 'layout.html.twig' %}

{% block title %}{{ trans('auth.two_factor_page_title') }} — Traventa{% endblock %}

{% block content %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 text-center">
                    <h4 class="mb-1">{{ trans('auth.two_factor_heading') }}</h4>
                    <p class="text-muted mb-4">{{ trans('auth.two_factor_verify_subtitle') }}</p>

                    {% if flash is defined %}
                        {% for type, messages in flash %}
                            {% for message in messages %}
                                <div class="alert alert-{{ type }} alert-dismissible fade show mb-4" role="alert">
                                    {% if type == 'success' %}
                                        ✔
                                    {% elseif type == 'danger' %}
                                        ✖
                                    {% elseif type == 'warning' %}
                                        ⚠
                                    {% elseif type == 'info' %}
                                        i
                                    {% endif %}                    
                                    {{ message }}
                                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                </div>
                            {% endfor %}
                        {% endfor %}
                    {% endif %}

                    <form method="POST" action="{{ base_path }}/auth/verify-2fa">
                        <div class="mb-4">
                            <input 
                                type="text" 
                                name="code" 
                                class="form-control form-control-lg text-center" 
                                placeholder="{{ trans('auth.code_placeholder') }}"
                                maxlength="6"
                                autocomplete="one-time-code"
                                autofocus
                                required>
                        </div>
                        <button type="submit" class="btn btn-success w-100">
                            {{ trans('auth.verify_btn') }}
                        </button>
                    </form>

                    <hr class="my-3">
                    <p class="text-center text-muted small mb-0">
                        <a href="{{ base_path }}/auth/login">
                            ← {{ trans('auth.back_to_login') }}
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}