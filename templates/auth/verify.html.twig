{% extends 'layout.html.twig' %}

{% block title %}Two-Factor Authentication — Traventa{% endblock %}

{% block content %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 text-center">
                    <h4 class="mb-1">Two-Factor Authentication</h4>
                    <p class="text-muted mb-4">Open your authenticator app and enter the 6-digit code for Traventa.</p>

                    {% if error %}
                        <div class="alert alert-danger py-2">{{ error }}</div>
                    {% endif %}

                    <form method="POST" action="{{ base_path }}/verify-2fa">
                        <div class="mb-4">
                            <input 
                                type="text" 
                                name="code" 
                                class="form-control form-control-lg text-center" 
                                placeholder="000000"
                                maxlength="6"
                                autocomplete="one-time-code"
                                autofocus
                                required>
                        </div>
                        <button type="submit" class="btn btn-success w-100">Verify</button>
                    </form>

                    <hr class="my-3">
                    <p class="text-center text-muted small mb-0">
                        <a href="{{ base_path }}/login">← Back to login</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}