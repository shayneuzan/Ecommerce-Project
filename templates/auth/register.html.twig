{% extends 'layout.html.twig' %}

{% block title %}{{ trans('auth.register_title') }} — Traventa{% endblock %}

{% block content %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">

            {% if step == 'qr_setup' %}
            {# ── Step 2: Show QR code after successful registration ── #}
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 text-center">
                    <h4 class="mb-1">{{ trans('auth.two_factor_title') }}</h4>
                    <p class="text-muted mb-3">{{ trans('auth.two_factor_subtitle') }}</p>

                    <img src="{{ qr_code }}" alt="{{ trans('auth.qr_code_alt') }}" class="img-fluid mb-3" style="max-width: 220px;">

                    <p class="text-muted small mb-4">{{ trans('auth.manual_setup_hint') }}</p>

                    <a href="{{ base_path }}/auth/login" class="btn btn-success w-100">
                        {{ trans('auth.scanned_go_login') }}
                    </a>
                </div>
            </div>

            {% else %}
            {# ── Step 1: Registration form ── #}
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h4 class="mb-1">{{ trans('auth.create_account_heading') }}</h4>
                    <p class="text-muted mb-4">{{ trans('auth.register_subtitle') }}</p>

                    {% if flash is defined %}
                        {% for type, messages in flash %}
                            {% for message in messages %}
                                <div class="alert alert-{{ type }} alert-dismissible fade show mb-4" role="alert">
                                    {% if type == 'success' %}
                                        ✔
                                    {% elseif type == 'danger' %}
                                        ✖
                                    {% elseif type == 'warning' %}
                                        ⚠
                                    {% elseif type == 'info' %}
                                        i
                                    {% endif %}                    
                                    {{ message }}
                                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                </div>
                            {% endfor %}
                        {% endfor %}
                    {% endif %} 

                    <form method="POST" action="{{ base_path }}/auth/register">
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label">{{ trans('auth.first_name') }}</label>
                                <input type="text" name="first_name" class="form-control" required>
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label">{{ trans('auth.last_name') }}</label>
                                <input type="text" name="last_name" class="form-control" required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">{{ trans('auth.email') }}</label>
                            <input type="email" name="email" class="form-control" required>
                        </div>
                        <div class="mb-4">
                            <label class="form-label">{{ trans('auth.password') }}</label>
                            <div class="input-group">
                                <input type="password" name="password" id="password" class="form-control" required>
                                <button class="btn btn-outline-secondary" type="button" id="toggleBtn" onclick="togglePassword()">{{ trans('auth.show') }}</button>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-success w-100">{{ trans('auth.register_btn') }}</button>
                    </form>

                    <hr class="my-3">
                    <p class="text-center text-muted small mb-0">
                        {{ trans('auth.already_have_account') }} <a href="{{ base_path }}/auth/login">{{ trans('auth.login_link') }}</a>
                    </p>
                </div>
            </div>
            {% endif %}

        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
    function togglePassword() {
        const input = document.getElementById('password');
        const btn = document.getElementById('toggleBtn');
        const isHidden = input.type === 'password';
        input.type = isHidden ? 'text' : 'password';
        btn.textContent = isHidden ? '{{ trans('auth.hide') }}' : '{{ trans('auth.show') }}';
    }
</script>
{% endblock %}