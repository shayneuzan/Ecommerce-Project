{% extends "layout.html.twig" %}

{% block title %}{{ package.title }}{% endblock %}

{% block content %}

<section class="page-hero">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="{{ base_path }}/" class="text-dark">
                        {{ trans('nav.home') }}
                    </a>
                </li>
                <li class="breadcrumb-item">
                    <a href="{{ base_path }}/packages" class="text-dark">
                        {{ trans('nav.packages') }}
                    </a>
                </li>
                <li class="breadcrumb-item active text-dark">{{ package.title }}</li>
            </ol>
        </nav>

        <h1 class="page-hero-title">{{ package.title }}</h1>
        <p class="page-hero-subtitle">{{ package.city }}, {{ package.country }}</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4">

            <div class="col-lg-8">
                <img
                    src="{{ package.image_url|default('https://images.unsplash.com/photo-1488646953014-85cb44e25828?w=800') }}"
                    onerror="this.src='{{ base_path ~ '/assets/images/no-image.jpg' }}'"
                    alt="{{ package.title }}"
                    class="img-fluid rounded-3 mb-4 w-100 package-detail-img"
                >

                <h4 class="section-title mb-3">
                    {{ trans('packages.about_package') }}
                </h4>

                <p class="text-muted">{{ package.description }}</p>

                <hr class="my-4">

                <div class="row g-3 mt-2">

                    <div class="col-md-4">
                        <div class="detail-card">
                            <div class="detail-card-label">
                                {{ trans('packages.hotel') }}
                            </div>

                            <div class="detail-card-value">{{ package.hotel_name }}</div>

                            <div class="detail-card-sub">
                                {{ package.hotel_address }}
                            </div>

                            <div class="detail-card-sub">
                                {{ trans('packages.rating') }}: {{ package.hotel_rating }}/5
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="detail-card">
                            <div class="detail-card-label">
                                {{ trans('packages.tour_guide') }}
                            </div>

                            <div class="detail-card-value">{{ package.guide_name }}</div>

                            <div class="detail-card-sub">
                                {{ package.guide_language }}
                            </div>

                            <div class="detail-card-sub">
                                {{ trans('packages.guide_fee') }}: ${{ package.guide_price }}
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="detail-card">
                            <div class="detail-card-label">
                                {{ trans('packages.destination') }}
                            </div>

                            <div class="detail-card-value">{{ package.city }}</div>

                            <div class="detail-card-sub">{{ package.country }}</div>

                            <div class="detail-card-sub">
                                {{ package.destination_description }}
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="col-lg-4">
                <div class="booking-card">

                    <div class="booking-card-price">
                        <span class="price-label1">
                            {{ trans('packages.price_per_person') }}
                        </span>

                        <br>

                        <span class="price-label">
                            {{ trans('packages.adult_price') }}
                        </span>

                        <span class="booking-price-value">
                            ${{ package.price }}
                        </span>

                        <br>

                        <span class="price-label mt-2">
                            {{ trans('packages.child_price') }}
                        </span>

                        <span class="booking-price-value">
                            ${{ package.price_child }}
                        </span>
                    </div>

                    <hr>

                    <ul class="list-unstyled">

                        <li class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">
                                {{ trans('packages.duration') }}
                            </span>

                            <span class="small fw-semibold">
                                {{ package.duration_days }} {{ trans('home.days') }}
                            </span>
                        </li>

                        <li class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">
                                {{ trans('packages.slots_available') }}
                            </span>

                            <span class="small fw-semibold">
                                {{ package.available_slots }}
                            </span>
                        </li>

                        <li class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">
                                {{ trans('packages.hotel') }}
                            </span>

                            <span class="small fw-semibold">
                                {{ package.hotel_name }}
                            </span>
                        </li>

                        <li class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">
                                {{ trans('packages.guide') }}
                            </span>

                            <span class="small fw-semibold">
                                {{ package.guide_name }}
                            </span>
                        </li>

                    </ul>

                    <hr>

                    {% if app_authenticated ?? false %}

                        <a href="{{ base_path }}/bookings/create/{{ package.id }}"
                           class="btn btn-teal btn-lg w-100">
                            {{ trans('packages.book_now') }}
                        </a>

                    {% else %}

                        <a href="{{ base_path }}/auth/login"
                           class="btn btn-teal btn-lg w-100">
                            {{ trans('packages.login_to_book') }}
                        </a>

                        <p class="text-center text-muted small mt-2">
                            {{ trans('auth.no_account') }}
                            <a href="{{ base_path }}/auth/register"
                               class="text-teal-link">
                                {{ trans('packages.signup_free') }}
                            </a>
                        </p>

                    {% endif %}

                    <a href="{{ base_path }}/packages"
                       class="btn btn-outline-secondary w-100 mt-2">
                        {{ trans('packages.back_to_packages') }}
                    </a>

                </div>
            </div>

        </div>
    </div>
</section>

{% endblock %}