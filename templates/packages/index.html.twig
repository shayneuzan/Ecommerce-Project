{# All packages page, 8 cards #}

{% extends "layout.html.twig" %}

{% block title %}{{ trans('packages.title') }}{% endblock %}

{% block content %}

<input type="hidden" id="base-path" value="{{ base_path }}">

{# ── Page hero ── #}
<section class="page-hero">
    <div class="container">
        <h1 class="page-hero-title">{{ trans('packages.hero_title') }}</h1>
        <p class="page-hero-subtitle">{{ trans('packages.hero_subtitle') }}</p>
        <div class="row justify-content-center mt-3">
            <div class="col-lg-6">
                <div class="input-group">
                    <input
                        type="text"
                        id="search-input"
                        class="form-control form-control-lg"
                        placeholder="{{ trans('packages.search_placeholder') }}"
                        value="{{ filters.search ?? '' }}"
                    >
                    <button class="btn btn-teal px-4" type="button">{{ trans('packages.search_btn') }}</button>
                </div>
            </div>
        </div>
    </div>
</section>

{# ── Main content ── #}
<section class="py-5">
    <div class="container">
        <div class="row g-4">

            {# ── Sidebar filters ── #}
            <div class="col-lg-3">
                <div class="filter-card">
                    <h6 class="filter-title">{{ trans('packages.filter_title') }}</h6>

                    <form method="GET" action="{{ base_path }}/packages" id="filter-form">

                        <div class="mb-3">
                            <label class="filter-label">{{ trans('packages.filter_country') }}</label>
                            <select name="country" class="form-select form-select-sm" onchange="this.form.submit()">
                                <option value="">{{ trans('packages.all_countries') }}</option>
                                {% for destination in countries %}
                                    <option value="{{ destination.country }}"
                                        {{ (filters.country ?? '') == destination.country ? 'selected' : '' }}>
                                        {{ destination.country }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="filter-label">{{ trans('packages.filter_duration') }}</label>
                            <select name="days" class="form-select form-select-sm" onchange="this.form.submit()">
                                <option value="">{{ trans('packages.any_duration') }}</option>
                                <option value="4" {{ (filters.days ?? '') == '4' ? 'selected' : '' }}>{{ trans('packages.up_to_4') }}</option>
                                <option value="6" {{ (filters.days ?? '') == '6' ? 'selected' : '' }}>{{ trans('packages.up_to_6') }}</option>
                                <option value="8" {{ (filters.days ?? '') == '8' ? 'selected' : '' }}>{{ trans('packages.up_to_8') }}</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="filter-label">{{ trans('packages.filter_budget') }}</label>
                            <select name="budget" class="form-select form-select-sm" onchange="this.form.submit()">
                                <option value="">{{ trans('packages.any_budget') }}</option>
                                <option value="1000" {{ (filters.budget ?? '') == '1000' ? 'selected' : '' }}>{{ trans('packages.under_1000') }}</option>
                                <option value="1300" {{ (filters.budget ?? '') == '1300' ? 'selected' : '' }}>{{ trans('packages.under_1300') }}</option>
                                <option value="1600" {{ (filters.budget ?? '') == '1600' ? 'selected' : '' }}>{{ trans('packages.under_1600') }}</option>
                                <option value="2000" {{ (filters.budget ?? '') == '2000' ? 'selected' : '' }}>{{ trans('packages.under_2000') }}</option>
                            </select>
                        </div>

                        {% if filters.country is defined and filters.country != ''
                            or filters.days is defined and filters.days != ''
                            or filters.budget is defined and filters.budget != '' %}
                            <a href="{{ base_path }}/packages" class="btn btn-outline-secondary btn-sm w-100">{{ trans('packages.clear_filters') }}</a>
                        {% endif %}

                    </form>
                </div>
            </div>

            {# ── Packages grid ── #}
            <div class="col-lg-9">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <p class="text-muted small mb-0">{{ packages|length }} {{ trans('packages.found') }}</p>
                </div>

                <div class="row g-4" id="packages-grid">
                    {% for package in packages %}
                        <div class="col-md-6 col-xl-4">
                            <div class="card package-card h-100">
                                <img
                                    src="{{ package.image_url|default('https://images.unsplash.com/photo-1488646953014-85cb44e25828?w=800') }}"
                                    onerror="this.src='{{ base_path ~ '/assets/images/no-image.jpg' }}'"
                                    class="card-img-top package-card-img"
                                    alt="{{ package.title }}"
                                    loading="lazy"
                                >
                                <div class="card-body d-flex flex-column">
                                    <p class="package-destination">{{ package.city }}</p>
                                    <h5 class="card-title package-title">{{ package.title }}</h5>
                                    <p class="card-text text-muted small flex-grow-1">{{ package.description }}</p>
                                    <div class="d-flex gap-3 my-2">
                                        <span class="small text-muted">{{ package.duration_days }} {{ trans('home.days') }}</span>
                                        <span class="small text-muted">{{ package.available_slots }} {{ trans('home.slots_left') }}</span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                                        <div>
                                            <div class="price-label">{{ trans('home.from') }}</div>
                                            <div class="price-value">${{ package.price }}<span class="price-per">/person</span></div>
                                        </div>
                                        <button class="btn btn-sm favourite-btn {{ package.id in favouriteIds ? 'btn-danger' : 'btn-outline-danger' }}"
                                            data-package-id="{{ package.id }}" title="{{ trans('packages.save_favourite') }}">
                                            &hearts;
                                        </button>
                                        <a href="{{ base_path }}/packages/{{ package.id }}" class="btn btn-teal btn-sm">{{ trans('home.view_deal') }}</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <div class="col-12">
                            <div class="text-center py-5 text-muted">
                                <p class="fs-5 mb-2">{{ trans('packages.no_packages') }}</p>
                                <a href="{{ base_path }}/packages" class="btn btn-outline-secondary btn-sm">{{ trans('packages.clear_filters') }}</a>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</section>

{% endblock %}

{% block scripts %}
<script src="{{ base_path }}/assets/js/packages.js"></script>
{% endblock %}