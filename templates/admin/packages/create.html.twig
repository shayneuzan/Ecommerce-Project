{# Admin Creating package form #}

{% extends "admin/dashboard.html.twig" %}

{% block title %}Create Package - {{ parent() }}{% endblock %}

{% block content %}
<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="section-title">Create Package</h2>
        <a href="{{ basePath }}/admin" class="btn btn-outline-navy">Back to Dashboard</a>
    </div>

    {# flash block for the create template #}
    {# renders any danger or success messages above the form so the admin can see what went wrong#}
    {% if flash is defined %}
        {% for type, messages in flash %}
            {% for message in messages %}
                <div class="alert alert-{{ type }} alert-dismissible fade show mb-3" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}
    {% endif %}

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body">
            <form action="{{ basePath }}/admin/packages/store" method="POST">

                {# ── Destination ── #}
                <h6 class="fw-bold mb-3 mt-2">Destination</h6>
                <div class="row gy-3 mb-4">
                    <div class="col-md-4">
                        <label class="form-label">City</label>
                        <input type="text" name="city" class="form-control" placeholder="e.g. Bangkok" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Country</label>
                        <input type="text" name="country" class="form-control" placeholder="e.g. Thailand" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Destination Description</label>
                        <input type="text" name="destination_description" class="form-control" placeholder="Brief description of the destination">
                    </div>
                </div>

                {# ── Hotel ── #}
                <h6 class="fw-bold mb-3">Hotel</h6>
                <div class="row gy-3 mb-4">
                    <div class="col-md-4">
                        <label class="form-label">Hotel Name</label>
                        <input type="text" name="hotel_name" class="form-control" placeholder="e.g. Bangkok Grand Hotel" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Hotel Address</label>
                        <input type="text" name="hotel_address" class="form-control" placeholder="e.g. 10 Sukhumvit Road, Bangkok">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Hotel Rating (1-5)</label>
                        <input type="number" name="hotel_rating" class="form-control" min="1" max="5" value="4" required>
                    </div>
                </div>

                {# ── Tour Guide ── #}
                <h6 class="fw-bold mb-3">Tour Guide</h6>
                <div class="row gy-3 mb-4">
                    <div class="col-md-4">
                        <label class="form-label">Guide Name</label>
                        <input type="text" name="guide_name" class="form-control" placeholder="e.g. Somchai Jaidee" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Languages</label>
                        <input type="text" name="guide_language" class="form-control" placeholder="e.g. English, Thai">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Guide Fee ($)</label>
                        <input type="number" name="guide_price" class="form-control" step="0.01" min="0" value="100.00">
                    </div>
                </div>

                {# ── Package Details ── #}
                <h6 class="fw-bold mb-3">Package Details</h6>
                <div class="row gy-3">
                    <div class="col-md-6">
                        <label class="form-label">Title</label>
                        <input type="text" name="title" class="form-control" placeholder="e.g. Bangkok Cultural Experience" required>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Adult Price ($)</label>
                        <input type="number" name="price" class="form-control" step="0.01" min="0" required>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Child Price ($)</label>
                        <input type="number" name="price_child" class="form-control" step="0.01" min="0">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Duration (days)</label>
                        <input type="number" name="duration_days" class="form-control" min="1" required>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Available Slots</label>
                        <input type="number" name="available_slots" class="form-control" min="0" value="10" required>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Minimum Age</label>
                        <input type="number" name="min_age" class="form-control" min="0" value="0">
                    </div>
                    <div class="col-md-9">
                        <label class="form-label">Image URL</label>
                        <input type="url" name="image_url" class="form-control" placeholder="https://images.unsplash.com/...">
                    </div>
                    <div class="col-12">
                        <label class="form-label">Description</label>
                        <textarea name="description" class="form-control" rows="4" placeholder="Describe what is included in this package..."></textarea>
                    </div>
                </div>

                <div class="mt-4 d-flex justify-content-end gap-2">
                    <a href="{{ basePath }}/admin" class="btn btn-secondary">Cancel</a>
                    <button type="submit" class="btn btn-teal">Create Package</button>
                </div>

            </form>
        </div>
    </div>
</div>
{% endblock %}