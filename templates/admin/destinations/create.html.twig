{% extends "admin/dashboard.html.twig" %}

{% block title %}Create Destination - {{ parent() }}{% endblock %}

{% block content %}
    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="section-title">Create Destination</h2>
            <a href="{{ basePath }}/admin" class="btn btn-outline-navy">Back to Dashboard</a>
        </div>

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body">
                <form action="{{ basePath }}/admin/destinations" method="POST">
                    <div class="row gy-3">
                        <div class="col-md-6">
                            <label for="city" class="form-label">City</label>
                            <input type="text" id="city" name="city" class="form-control" value="{{ destination.city|default('') }}" required>
                        </div>
                        <div class="col-md-6">
                            <label for="country" class="form-label">Country</label>
                            <input type="text" id="country" name="country" class="form-control" value="{{ destination.country|default('') }}" required>
                        </div>
                        <div class="col-12">
                            <label for="description" class="form-label">Description</label>
                            <textarea id="description" name="description" class="form-control" rows="5">{{ destination.description|default('') }}</textarea>
                        </div>
                    </div>

                    <div class="mt-4 d-flex justify-content-end gap-2">
                        <a href="{{ basePath }}/admin" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-teal">Create Destination</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
