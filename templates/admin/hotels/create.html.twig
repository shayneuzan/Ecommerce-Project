{% extends "admin/dashboard.html.twig" %}

{% block title %}Create Hotel - {{ parent() }}{% endblock %}

{% block content %}
    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="section-title">Create Hotel</h2>
            <a href="{{ basePath }}/admin" class="btn btn-outline-navy">Back to Dashboard</a>
        </div>

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body">
                <form action="{{ basePath }}/admin/hotels" method="POST">
                    <div class="row gy-3">
                        <div class="col-md-6">
                            <label for="hotel_name" class="form-label">Hotel Name</label>
                            <input type="text" id="hotel_name" name="hotel_name" class="form-control" value="{{ hotel.hotel_name|default('') }}" required>
                        </div>
                        <div class="col-md-6">
                            <label for="address" class="form-label">Address</label>
                            <input type="text" id="address" name="address" class="form-control" value="{{ hotel.address|default('') }}" required>
                        </div>
                        <div class="col-md-6">
                            <label for="rating" class="form-label">Rating</label>
                            <input type="number" id="rating" name="rating" class="form-control" step="0.1" min="1" max="5" value="1" placeholder="Enter rating (1-5)" required>
                        </div>
                        <div class="col-md-4">
                            <label for="destination_id" class="form-label">Destination</label>
                            <select id="destination_id" name="destination_id" class="form-select" required>
                                <option value="">Select destination</option>
                                {% for destination in destinations %} 
                                    <option value="{{ destination.id }}">{{ destination.city }}, {{ destination.country }}</option>
                                {% endfor %}
                            </select>
                        </div>                        
                    </div>

                    <div class="mt-4 d-flex justify-content-end gap-2">
                        <a href="{{ basePath }}/admin" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-teal">Create Hotel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
