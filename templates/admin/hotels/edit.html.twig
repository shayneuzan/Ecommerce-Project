{% extends "admin/dashboard.html.twig" %}

{% block title %}Edit Hotel - Admin Dashboard - Traventa{% endblock %}

{% block content %}
<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="section-title">Edit Hotel</h2>
            <p class="text-muted">Update hotel details and save your changes.</p>
        </div>
        <a href="{{ basePath }}/admin" class="btn btn-outline-navy">Back to Dashboard</a>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body">
            <form action="{{ basePath }}/admin/hotels/{{ hotel.id }}/update" method="post">
                <div class="row gy-3">
                    <div class="col-md-6">
                        <label for="hotel_name" class="form-label">Hotel Name</label>
                        <input type="text" id="hotel_name" name="hotel_name" class="form-control" value="{{ hotel.hotel_name }}" required>
                    </div>
                    <div class="col-md-6">
                        <label for="address" class="form-label">Address</label>
                        <input type="text" id="address" name="address" class="form-control" value="{{ hotel.address }}" required>
                    </div>
                    <div class="col-md-6">
                        <label for="rating" class="form-label">Rating</label>
                        <input type="number" id="rating" name="rating" class="form-control" step="0.1" min="0" max="5" value="{{ hotel.rating }}">
                    </div>
                </div>

                <div class="mt-4 d-flex justify-content-end gap-2">
                    <a href="{{ basePath }}/admin" class="btn btn-secondary">Cancel</a>
                    <button type="submit" class="btn btn-teal">Update Hotel</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}