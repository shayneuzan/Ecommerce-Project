{% extends 'layout.html.twig' %}

{% block title %}{{ trans('bookings.page_title') }} — Traventa{% endblock %}

{% block content %}
<div class="container py-5">

    <h2 class="mb-4">{{ trans('bookings.my_bookings') }}</h2>

    {% if bookings is empty %}

        <div class="text-center py-5">
            <p class="text-muted">
                {{ trans('bookings.no_bookings') }}
            </p>

            <a href="{{ base_path }}/packages"
               class="btn btn-success">
                {{ trans('bookings.browse_packages') }}
            </a>
        </div>

    {% else %}

        <div class="row g-4">

            {% for booking in bookings %}

            <div class="col-md-6">
                <div class="card shadow-sm border-0">

                    <div class="card-body p-4">

                        <div class="d-flex justify-content-between align-items-start mb-3">

                            <h5 class="mb-0">
                                {{ trans('bookings.booking_number') }} #{{ booking.reference }}
                            </h5>

                            <span class="badge bg-success">
                                {{ booking.status }}
                            </span>

                        </div>

                        <p class="text-muted small mb-1">
                            {{ trans('bookings.travel_date') }}:
                            {{ booking.travel_date }}
                        </p>

                        <p class="text-muted small mb-1">
                            {{ trans('bookings.booked_on') }}:
                            {{ booking.booking_date }}
                        </p>

                        <p class="text-muted small mb-3">
                            {{ trans('bookings.payment') }}:
                            {{ booking.payment_status }}
                        </p>

                        <div class="d-flex justify-content-between align-items-center border-top pt-3">

                            <span class="fw-bold">
                                {{ trans('bookings.total') }}:
                                ${{ booking.total_price }}
                            </span>

                            <a href="{{ base_path }}/booking/confirmation/{{ booking.id }}"
                               class="btn btn-outline-success btn-sm">
                                {{ trans('bookings.view_details') }}
                            </a>

                        </div>

                    </div>
                </div>
            </div>

            {% endfor %}

        </div>

    {% endif %}
</div>
{% endblock %}