{% extends 'layout.html.twig' %}

{% block title %}My Bookings — Traventa{% endblock %}

{% block content %}
<div class="container py-5">
    <h2 class="mb-4">My Bookings</h2>

    {% if bookings is empty %}
        <div class="text-center py-5">
            <p class="text-muted">You haven't made any bookings yet.</p>
            <a href="{{ base_path }}/packages" class="btn btn-success">Browse Packages</a>
        </div>
    {% else %}
        <div class="row g-4">
            {% for booking in bookings %}
            <div class="col-md-6">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h5 class="mb-0">Booking #{{ booking.reference }}</h5>
                            <span class="badge bg-success">{{ booking.status }}</span>
                        </div>
                        <p class="text-muted small mb-1">Travel Date: {{ booking.travel_date }}</p>
                        <p class="text-muted small mb-1">Booked On: {{ booking.booking_date }}</p>
                        <p class="text-muted small mb-3">Payment: {{ booking.payment_status }}</p>
                        <div class="d-flex justify-content-between align-items-center border-top pt-3">
                            <span class="fw-bold">Total: ${{ booking.total_price }}</span>
                            <a href="{{ base_path }}/booking/confirmation/{{ booking.id }}" class="btn btn-outline-success btn-sm">View Details</a>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}