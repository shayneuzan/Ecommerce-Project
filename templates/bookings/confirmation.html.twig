{# Confirmation Page - booking receipt #}

{% extends "layout.html.twig" %}

{% block title %}Booking Confirmed{% endblock %}

{% block content %}

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">

                {# ── Success Banner ── #}
                <div class="text-center mb-5">
                    <div class="mb-3" style="font-size: 3rem;">✅</div>
                    <h2 class="section-title">Booking Confirmed!</h2>
                    <p class="text-muted">Your trip has been booked successfully. A confirmation email has been sent.</p>
                </div>

                {# ── Reference Number ── #}
                <div class="card mb-4 border-0 bg-light text-center">
                    <div class="card-body py-4">
                        <p class="text-muted small mb-1">Booking Reference</p>
                        <h3 class="fw-bold text-teal">{{ booking.reference }}</h3>
                        <p class="text-muted small mb-0">Keep this reference number for your records</p>
                    </div>
                </div>

                {# ── Trip Summary ── #}
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-4">Trip Summary</h5>

                        <div class="d-flex gap-3 mb-3">
                            <img
                                src="{{ package.image_url ?? 'https://images.unsplash.com/photo-1488646953014-85cb44e25828?w=800' }}"
                                class="rounded"
                                style="width:90px; height:70px; object-fit:cover;"
                                alt="{{ package.title }}"
                            >
                            <div>
                                <p class="fw-semibold mb-0">{{ package.title }}</p>
                                <p class="text-muted small mb-0">{{ package.duration_days }} days</p>
                                <p class="text-muted small mb-0">Travel Date: <strong>{{ booking.travel_date }}</strong></p>
                            </div>
                        </div>

                        <hr>

                        {# Passenger list #}
                        <h6 class="fw-semibold mb-3">Passengers</h6>
                        {% for passenger in passengers %}
                            <div class="d-flex justify-content-between align-items-center small mb-2">
                                <div>
                                    <span>{{ passenger.first_name }} {{ passenger.last_name }}</span>
                                    <span class="badge bg-light text-dark ms-2">{{ passenger.passenger_type }}</span>
                                    <span class="text-muted ms-1">(age {{ passenger.age }})</span>
                                </div>
                                <span>
                                    {% if passenger.price == 0 %}
                                        Free
                                    {% else %}
                                        ${{ passenger.price }}
                                    {% endif %}
                                </span>
                            </div>
                        {% endfor %}

                        <hr>

                        {# Total #}
                        <div class="d-flex justify-content-between fw-bold">
                            <span>Total Paid</span>
                            <span class="text-teal">${{ booking.total_price }}</span>
                        </div>
                    </div>
                </div>

                {# ── Booking Status ── #}
                <div class="card mb-4">
                    <div class="card-body">
                        <div class="row text-center g-3">
                            <div class="col-4">
                                <p class="text-muted small mb-1">Status</p>
                                <span class="badge bg-success">{{ booking.status|capitalize }}</span>
                            </div>
                            <div class="col-4">
                                <p class="text-muted small mb-1">Payment</p>
                                <span class="badge bg-success">{{ booking.payment_status|capitalize }}</span>
                            </div>
                            <div class="col-4">
                                <p class="text-muted small mb-1">Booked On</p>
                                <span class="small">{{ booking.created_at|date("M d, Y") }}</span>
                            </div>
                        </div>
                    </div>
                </div>

                {# ── Actions ── #}
                <div class="d-flex gap-3">
                    <a href="{{ basePath }}/packages" class="btn btn-teal w-100">
                        Browse More Packages
                    </a>
                    <a href="{{ basePath }}/" class="btn btn-outline-navy w-100">
                        Back to Home
                    </a>
                </div>

            </div>
        </div>
    </div>
</section>

{% endblock %}
