{
    "name": "traventa/vacation-booking",
    "description": "Traventa - Vacation Package Booking Website",
    "require": {
        "slim/slim": "^4.0",
        "slim/psr7": "^1.0",
        "php-di/php-di": "^7.0",
        "twig/twig": "^3.0",
        "gabordemooij/redbean": "^5.7",
        "robthree/twofactorauth": "^2.0",
        "vlucas/phpdotenv": "^5.0",
        "bacon/bacon-qr-code": "^3.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
