# Copy this file to .env and fill in your values
# Never commit .env to GitHub

#do: "cp .env.example .env" and fill in your DB credentials"

APP_ENV=development         # tells the app if its running locally or on Railway
APP_BASE_PATH=/traventa     # the URL path your app runs under on WAMP

DB_HOST=localhost           # your database server (always localhost on WAMP)
DB_NAME=traventa            # the name of the database created in phpMyAdmin
DB_USER=root                # default WAMP username
DB_PASS=                    # empty by default on WAMP, fill in if we set a password

GOOGLE_AI_API_KEY=          # Daveena's chatbot feature from Google AI Studio

